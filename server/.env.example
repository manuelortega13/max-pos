# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored; `.env.example` is committed as documentation.

# ── PostgreSQL ──────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/maxpos
DB_USERNAME=maxpos
DB_PASSWORD=

# ── JWT ─────────────────────────────────────────────────────────────────────
# Generate with:  openssl rand -base64 48
JWT_SECRET=
JWT_TTL_MINUTES=480

# ── Server ──────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ── Web Push (VAPID) ────────────────────────────────────────────────────────
# Generate a new keypair with:  npx web-push generate-vapid-keys --json
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
